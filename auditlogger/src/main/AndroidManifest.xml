<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1. Định nghĩa Permission bảo vệ Broadcast Receiver của Audit Logger -->
    <permission
        android:name="com.example.auditlogger.permission.WRITE_AUDIT_LOG"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.auditlogger.permission.WRITE_AUDIT_LOG" />

    <!-- 2. Khai báo quyền để đọc Provider của Secret Notes -->
    <uses-permission android:name="com.example.secretnotes.permission.READ_SECRET_NOTES" />

    <!-- 3. Khai báo package Secret Notes (Bắt buộc từ Android 11+ để 2 app thấy nhau) -->
    <queries>
        <package android:name="com.example.secretnotes" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Audit Logger"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Demo">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Audit Logger"
            android:theme="@style/Theme.Demo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 4. Broadcast Receiver được bảo vệ bởi Permission -->
        <receiver
            android:name=".AuditLogReceiver"
            android:exported="true"
            android:permission="com.example.auditlogger.permission.WRITE_AUDIT_LOG">
            <intent-filter>
                <action android:name="com.example.auditlogger.action.WRITE_LOG" />
            </intent-filter>
        </receiver>

    </application>

</manifest>